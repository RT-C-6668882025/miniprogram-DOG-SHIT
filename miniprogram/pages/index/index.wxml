<!--荒谬论文首页 - 学术极简风-->
<view class="page">
  <!-- 顶部装饰条 -->
  <view class="academic-header"></view>

  <!-- 主内容区 -->
  <view class="content">

    <!-- Logo 区 - 点击5次或长按3秒触发管理员入口 -->
    <view class="logo-section anim-container" bindtap="onLogoTap" bindlongpress="onLogoLongPress">
      <text class="journal-name">DOG SHIT</text>
      <text class="journal-subtitle">构思的含金量还在上升</text>
      <view class="divider-line"></view>
    </view>

    <!-- 简介 -->
    <view class="intro-section anim-container">
      <text class="intro-text">生成结构严肃的构思论文</text>
      <text class="intro-subtext">基于 AI 的学术娱乐系统</text>
    </view>

    <!-- 核心功能入口 -->
    <view class="feature-section anim-container">
      <!-- 论文生成 -->
      <view class="feature-card btn btn-default btn-md" bindtap="goToPaper">
        <view class="feature-icon">
          <text class="icon-emoji">📝</text>
        </view>
        <text class="feature-title">构思论文</text>
        <text class="feature-desc">创建你的荒谬研究</text>
      </view>

      <!-- 排行榜 -->
      <view class="feature-card btn btn-default btn-md" bindtap="goToRanking">
        <view class="feature-icon">
          <text class="icon-emoji">🏆</text>
        </view>
        <text class="feature-title">学术排行榜</text>
        <text class="feature-desc">查看构思一区论文</text>
      </view>
    </view>

    <!-- 示例论文列表 -->
    <view class="example-section anim-container">
      <view class="section-header">
        <text class="section-title">Featured Papers</text>
        <view class="section-line"></view>
      </view>

      <!-- 预设论文卡片列表 -->
      <view class="paper-list">
        <view 
          class="example-card" 
          wx:for="{{featuredPapers}}" 
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="goToDetail"
        >
          <view class="example-badge">{{item.zone}}</view>
          <text class="example-title">{{item.title}}</text>
          <view class="example-meta">
            <text class="meta-tag">AIF {{item.aif}}</text>
            <text class="meta-tag">{{item.citations}} citations</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部信息 -->
    <view class="footer anim-container">
      <text class="footer-text">Generated by AI · For Entertainment Only</text>
    </view>

  </view>
</view>
