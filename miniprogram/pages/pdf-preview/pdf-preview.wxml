<!-- pages/pdf-preview/pdf-preview.wxml -->
<view class="pdf-preview-page">
  <!-- 顶部导航栏 -->
  <view class="pdf-header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">←</text>
      <text class="back-text">返回</text>
    </view>
    <text class="header-title">PDF预览</text>
    <view class="header-right">
      <text class="action-text" bindtap="sharePDF">分享</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载PDF...</text>
  </view>

  <!-- PDF内容 - 使用rich-text组件显示 -->
  <scroll-view class="pdf-content" scroll-y wx:if="{{!loading && htmlContent}}">
    <rich-text nodes="{{htmlContent}}"></rich-text>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="pdf-footer">
    <button class="btn btn-primary btn-sm" bindtap="copyHTML">复制HTML</button>
    <button class="btn btn-default btn-sm" bindtap="savePDF">保存到相册</button>
  </view>
</view>
