/* pages/pdf-preview/pdf-preview.wxss */

.pdf-preview-page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 顶部导航栏 */
.pdf-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background: #fff;
  border-bottom: 1rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  z-index: 100;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx;
  margin: -20rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
}

.back-text {
  font-size: 28rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  padding: 20rpx;
  margin: -20rpx;
}

.action-text {
  font-size: 28rpx;
  color: #007aff;
}

/* 加载状态 */
.loading-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e5e5;
  border-top-color: #007aff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* PDF内容区域 */
.pdf-content {
  flex: 1;
  margin-top: 88rpx;
  margin-bottom: 100rpx;
  padding: 20rpx;
  background: #fff;
}

/* 底部操作栏 */
.pdf-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  padding: 0 30rpx;
  z-index: 100;
}

/* 按钮样式 */
.btn {
  min-width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-primary {
  background: #007aff;
  color: #fff;
}

.btn-default {
  background: #f5f5f5;
  color: #333;
  border: 1rpx solid #ddd;
}

.btn-sm {
  font-size: 26rpx;
  height: 64rpx;
  line-height: 64rpx;
}
