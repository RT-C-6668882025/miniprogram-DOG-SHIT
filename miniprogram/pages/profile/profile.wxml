<!--pages/profile/profile.wxml-->
<view class="profile-page">
  <!-- 顶部装饰条 -->
  <view class="academic-header"></view>

  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar-section">
      <view class="avatar-ring">
        <image class="user-avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickname || '研究员'}}</text>
        <text class="user-bio">{{userInfo.bio || '暂无简介'}}</text>
      </view>
    </view>

    <!-- 统计数据 -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-number">{{userStats.papersCount || 0}}</text>
        <text class="stat-label">论文</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{userStats.totalCitations || 0}}</text>
        <text class="stat-label">引用</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number">{{userStats.highestAIF || 0}}</text>
        <text class="stat-label">最高AIF</text>
      </view>
    </view>

    <!-- 最佳成就 -->
    <view class="achievement" wx:if="{{userStats.bestZone}}">
      <text class="achievement-badge zone-{{getZoneClass(userStats.bestZone)}}">
        {{userStats.bestZone}}
      </text>
      <text class="achievement-text">最高成就</text>
    </view>
  </view>

  <!-- 我的论文列表 -->
  <view class="section-header">
    <text class="section-title">我的研究</text>
    <view class="section-line"></view>
  </view>

  <view class="papers-list" wx:if="{{myPapers.length > 0}}">
    <view class="paper-item" wx:for="{{myPapers}}" wx:key="_id" bindtap="viewPaper" data-id="{{item._id}}">
      <view class="paper-header">
        <view class="zone-tag zone-{{getZoneClass(item.zone)}}">{{item.zone}}</view>
        <text class="paper-aif">AIF {{item.aif.total}}</text>
      </view>
      <text class="paper-title">{{item.title}}</text>
      <view class="paper-footer">
        <text class="paper-date">{{item.createdAt}}</text>
        <text class="paper-citations">{{item.citations}} 引用</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">📝</text>
    <text class="empty-text">还没有论文</text>
    <text class="empty-hint">去生成你的第一篇荒谬论文吧</text>
    <button class="empty-btn" bindtap="goToCreate">立即创建</button>
  </view>

  <!-- 功能入口 -->
  <view class="action-section">
    <view class="action-item" bindtap="goToCreate">
      <view class="action-icon">📝</view>
      <text class="action-label">生成论文</text>
      <view class="action-arrow">→</view>
    </view>
    <view class="action-item" bindtap="goToSettings">
      <view class="action-icon">⚙️</view>
      <text class="action-label">设置</text>
      <view class="action-arrow">→</view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">Generated by AI · For Entertainment Only</text>
  </view>
</view>
