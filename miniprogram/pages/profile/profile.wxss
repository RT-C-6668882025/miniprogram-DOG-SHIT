/* pages/profile/profile.wxss - 用户个人中心 */

.profile-page {
  min-height: 100vh;
  background: #ffffff;
  padding-bottom: 40rpx;
}

/* ========== 顶部装饰条 ========== */
.academic-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--academic-blue), var(--academic-blue-light));
  z-index: 1000;
}

/* ========== 用户卡片 ========== */
.user-card {
  margin: 40rpx;
  padding: 40rpx;
  background: var(--academic-bg);
  border: 1rpx solid var(--academic-border-light);
  border-radius: 8rpx;
}

.user-avatar-section {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 2rpx solid var(--academic-border);
  padding: 4rpx;
  margin-right: 24rpx;
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--academic-bg);
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-family: 'Times New Roman', serif;
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.user-bio {
  display: block;
  font-size: 22rpx;
  color: var(--academic-grey);
}

/* ========== 统计数据 ========== */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-family: 'Times New Roman', serif;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--academic-blue);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--academic-grey);
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: var(--academic-border-light);
}

/* ========== 成就 ========== */
.achievement {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx;
  margin-top: 20rpx;
  background: #ffffff;
  border-radius: 6rpx;
}

.achievement-badge {
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  color: #ffffff;
}

.zone-SSS { background: #dc2626; }
.zone-S { background: #ea580c; }
.zone-A { background: #16a34a; }
.zone-B { background: #2563eb; }
.zone-C { background: #6b7280; }

.achievement-text {
  font-size: 22rpx;
  color: var(--academic-grey);
}

/* ========== 章节标题 ========== */
.section-header {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx 20rpx;
}

.section-title {
  font-family: 'Times New Roman', serif;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--academic-grey);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-right: 16rpx;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: var(--academic-border-light);
}

/* ========== 论文列表 ========== */
.papers-list {
  padding: 0 40rpx;
}

.paper-item {
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
  border: 1rpx solid var(--academic-border-light);
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.paper-item:active {
  border-color: var(--academic-blue);
  box-shadow: 0 4rpx 16rpx rgba(30, 58, 95, 0.1);
}

.paper-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.zone-tag {
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  color: #ffffff;
}

.paper-aif {
  font-size: 22rpx;
  color: var(--academic-blue);
  font-family: 'Times New Roman', serif;
}

.paper-title {
  display: block;
  font-family: 'Times New Roman', serif;
  font-size: 26rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.paper-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.paper-date {
  font-size: 20rpx;
  color: var(--academic-grey);
}

.paper-citations {
  font-size: 20rpx;
  color: var(--academic-blue);
}

/* ========== 空状态 ========== */
.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-family: 'Times New Roman', serif;
  font-size: 28rpx;
  color: var(--academic-grey);
  margin-bottom: 12rpx;
}

.empty-hint {
  display: block;
  font-size: 22rpx;
  color: var(--academic-grey);
  opacity: 0.6;
  margin-bottom: 30rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: var(--academic-blue);
  color: #ffffff;
  border: none;
  border-radius: 6rpx;
  font-size: 24rpx;
}

/* ========== 功能入口 ========== */
.action-section {
  margin: 20rpx 40rpx;
  border: 1rpx solid var(--academic-border-light);
  border-radius: 8rpx;
  overflow: hidden;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--academic-border-light);
  transition: background 0.2s ease;
}

.action-item:last-child {
  border-bottom: none;
}

.action-item:active {
  background: var(--academic-bg);
}

.action-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.action-label {
  flex: 1;
  font-size: 26rpx;
  color: #1a1a1a;
}

.action-arrow {
  font-size: 24rpx;
  color: var(--academic-grey);
}

/* ========== 底部 ========== */
.footer {
  text-align: center;
  padding: 30rpx 40rpx;
  border-top: 1rpx solid var(--academic-border-light);
  margin-top: 40rpx;
}

.footer-text {
  font-family: 'Times New Roman', serif;
  font-size: 20rpx;
  color: var(--academic-grey);
  font-style: italic;
}
