/* 全局样式 - 学术极简风 */
@import './styles/button-system.wxss';
@import './styles/icon-font.wxss';

page {
  background: #ffffff;
  min-height: 100vh;
  color: #1a1a1a;
  font-family: 'Times New Roman', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

/* 学术色彩变量 */
page {
  --academic-blue: #1e3a5f;
  --academic-blue-light: #2d5a87;
  --academic-grey: #6b7280;
  --academic-grey-light: #e5e7eb;
  --academic-bg: #f9fafb;
  --academic-border: #d1d5db;
  --academic-border-light: #f3f4f6;
}

/* 全局动画容器 */
.anim-container {
  animation-duration: 0.6s;
  animation-timing-function: ease-out;
  animation-fill-mode: both;
}

/* 淡入进场 */
.fade-in {
  animation-name: fadeIn;
}

@keyframes fadeIn {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}

/* 从下滑入 */
.slide-up {
  animation-name: slideUp;
}

@keyframes slideUp {
  0% {
    opacity: 0;
    transform: translateY(20px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 从左滑入 */
.slide-in-left {
  animation-name: slideInLeft;
}

@keyframes slideInLeft {
  0% {
    opacity: 0;
    transform: translateX(-30px);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 缩放进场 */
.scale-in {
  animation-name: scaleIn;
}

@keyframes scaleIn {
  0% {
    opacity: 0;
    transform: scale(0.95);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 延迟工具类 */
.delay-100 { animation-delay: 0.05s; }
.delay-200 { animation-delay: 0.1s; }
.delay-300 { animation-delay: 0.15s; }
.delay-400 { animation-delay: 0.2s; }
.delay-500 { animation-delay: 0.25s; }
.delay-600 { animation-delay: 0.3s; }

/* 全局容器 */
.page-container {
  min-height: 100vh;
  background: #ffffff;
}
