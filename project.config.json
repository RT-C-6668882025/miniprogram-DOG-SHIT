  "condition": {},
  "srcMiniprogramRoot": "miniprogram/",
  "editorSetting": {
    "tabIndent": "insertSpaces",
    "tabSize": 2
  },
  "libVersion": "3.0.0",
  "packOptions": {
    "ignore": [],
    "include": []
  },
  "appid": "your-appid-here"
